{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SecureFolders",
  "version": "0.17.1",
  "identifier": "com.securefolders.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SecureFolders",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/securefolders-exports/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRTdGMzYwRDY1MkVFMTgKUldRWTdsTFdZUFBucnoyQXdSZ1JQS1RBZXBmcXY1a3ZzMG8xUkRKekUyTXdUUXZIK01oUFEySFkK",
      "endpoints": [
        "https://github.com/Xoriax/securefolders/releases/latest/download/latest.json"
      ]
    }
  }
}
